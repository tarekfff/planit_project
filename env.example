# =================================================================
# .env.example — Planit
#
# 1. Copy this file:   cp .env.example .env
# 2. Fill in values from your Supabase project dashboard:
#    https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
#
# NEVER commit .env to git. It is already in .gitignore.
# =================================================================


# ------------------------------------------------------------------
# Supabase — required
# Find these in: Supabase Dashboard → Settings → API
# ------------------------------------------------------------------

# Your project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Anon/public key (safe to expose to the browser — RLS protects your data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Service role key — SERVER SIDE ONLY, never prefix with NEXT_PUBLIC_
# Use this only in trusted server code (admin operations, migrations)
# Leave blank if you don't need admin DB access from the app
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here


# ------------------------------------------------------------------
# Next.js — optional but recommended
# ------------------------------------------------------------------

# The public URL of your deployed app (used for redirects, OG images, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret used to sign cookies — generate with: openssl rand -hex 32
# Required for custom auth flows. Supabase SSR handles its own signing.
NEXTAUTH_SECRET=


# ------------------------------------------------------------------
# Docker — optional
# ------------------------------------------------------------------

# Port exposed by Docker (default: 3000)
PORT=3000
